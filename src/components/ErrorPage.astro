---
import Base from '../layouts/Base.astro';

interface Props {
  code: string;
  eyebrow?: string;
  title: string;
  description: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  code,
  eyebrow = 'Page status',
  title,
  description,
  primaryHref = '/',
  primaryLabel = 'Back to homepage',
  secondaryHref = 'mailto:support@commerceforge.dev',
  secondaryLabel = 'Contact support',
} = Astro.props;

const hasSecondaryAction = Boolean(secondaryHref && secondaryLabel);
---

<Base title={`${code} — ${title} | CommerceForge`} description={description} noindex>
  <main class="relative min-h-screen overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,#27272a_1px,transparent_1px),linear-gradient(to_bottom,#27272a_1px,transparent_1px)] bg-[size:48px_48px] opacity-25"
    ></div>
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(99,102,241,0.2),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(59,130,246,0.16),transparent_30%)]"
    ></div>

    <section class="relative px-6 py-10">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight text-zinc-50">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="h-7 w-7">
            <rect width="32" height="32" rx="8" fill="#6366f1"/>
            <path d="M8 10h10a6 6 0 0 1 0 12H8V10z" fill="white"/>
            <rect x="8" y="14" width="8" height="4" rx="1" fill="#6366f1"/>
          </svg>
          CommerceForge
        </a>
        {hasSecondaryAction && (
          <a
            href={secondaryHref}
            class="hidden rounded-full border border-zinc-800 bg-zinc-900/80 px-4 py-2 text-sm text-zinc-300 transition hover:border-zinc-700 hover:text-zinc-50 sm:inline-flex"
          >
            {secondaryLabel}
          </a>
        )}
      </div>
    </section>

    <section class="relative flex min-h-[calc(100vh-96px)] items-center px-6 pb-20 pt-8">
      <div class="mx-auto grid w-full max-w-6xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_380px] lg:items-center">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-3 rounded-full border border-zinc-800 bg-zinc-900/90 px-4 py-2 text-sm text-zinc-400">
            <span class="font-mono text-zinc-200">{code}</span>
            <span class="h-1.5 w-1.5 rounded-full bg-indigo-400"></span>
            {eyebrow}
          </div>

          <h1 class="mt-6 max-w-xl text-5xl font-bold leading-tight tracking-tight text-zinc-50 md:text-6xl">
            {title}
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-relaxed text-zinc-400">
            {description}
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a
              href={primaryHref}
              class="inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-indigo-950/40 transition hover:bg-indigo-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-300"
            >
              {primaryLabel}
            </a>
            {hasSecondaryAction && (
              <a
                href={secondaryHref}
                class="inline-flex items-center justify-center rounded-2xl border border-zinc-800 bg-zinc-900/80 px-6 py-3.5 text-base font-medium text-zinc-300 transition hover:border-zinc-700 hover:text-zinc-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400"
              >
                {secondaryLabel}
              </a>
            )}
          </div>
        </div>

        <div class="rounded-[2rem] border border-zinc-800 bg-zinc-900/90 p-5 shadow-2xl shadow-black/30">
          <div class="flex items-center gap-2 border-b border-zinc-800 pb-4">
            <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
            <span class="ml-2 font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">
              system status
            </span>
          </div>
          <div class="space-y-4 px-1 py-5">
            <div class="rounded-2xl border border-zinc-800 bg-zinc-950/80 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">Request</p>
              <p class="mt-3 font-mono text-sm text-zinc-300">GET {Astro.url.pathname}</p>
            </div>
            <div class="rounded-2xl border border-zinc-800 bg-zinc-950/80 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-zinc-500">Response</p>
              <p class="mt-3 font-mono text-sm text-zinc-300">{code}</p>
            </div>
            <div class="rounded-2xl border border-indigo-500/30 bg-indigo-500/10 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-indigo-200/80">Next step</p>
              <p class="mt-3 text-sm leading-relaxed text-zinc-300">
                Use the primary action to continue browsing or contact support if the issue persists.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
