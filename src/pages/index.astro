            tiers.map((tier) => (
              <div
                class={`relative flex flex-col rounded-xl border p-8 ${
                  tier.highlight
                    ? 'border-indigo-500 bg-indigo-950/40 shadow-[0_0_60px_-10px_rgba(99,102,241,0.3)]'
