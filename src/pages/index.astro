---

<Base>
  <!-- ─── NAV ─────────────────────────────────────────────────────── -->
  <header class="sticky top-0 z-50 border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md">
    <nav class="mx-auto max-w-6xl px-6 py-4">
      <div class="flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight text-zinc-50">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="h-7 w-7">
            <rect width="32" height="32" rx="8" fill="#6366f1"/>
            <path d="M8 10h10a6 6 0 0 1 0 12H8V10z" fill="white"/>
            <rect x="8" y="14" width="8" height="4" rx="1" fill="#6366f1"/>
          </svg>
          CommerceForge
        </a>
        <div class="hidden items-center gap-6 text-sm md:flex">
          <a href="https://demo.commerceforge.dev" target="_blank" class="text-zinc-400 transition hover:text-zinc-50">Demo</a>
          <a href="#features" class="text-zinc-400 transition hover:text-zinc-50">Features</a>
          <a href="#pricing" class="text-zinc-400 transition hover:text-zinc-50">Pricing</a>
          <a href="#faq" class="text-zinc-400 transition hover:text-zinc-50">FAQ</a>
          <a
            href="#pricing"
            class="rounded-md bg-indigo-600 px-4 py-2 font-medium text-white transition hover:bg-indigo-500"
          >
            Get started
          </a>
        </div>
        <button
          type="button"
          class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-zinc-800 bg-zinc-900 text-zinc-200 transition hover:border-zinc-700 hover:text-zinc-50 md:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-haspopup="dialog"
          aria-label="Open navigation menu"
          data-menu-toggle
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M4 7h16" />
            <path d="M4 12h16" />
            <path d="M4 17h16" />
          </svg>
        </button>
      </div>
      <dialog
        id="mobile-menu"
        class="m-0 h-full max-h-none w-full max-w-none overflow-hidden border-0 bg-transparent p-0 text-left text-zinc-50 backdrop:bg-zinc-950/70 backdrop:backdrop-blur-sm md:hidden"
        aria-labelledby="mobile-menu-title"
        data-mobile-menu
      >
        <div class="relative flex min-h-full items-start justify-end p-4 sm:p-6">
          <button
            type="button"
            class="absolute inset-0 cursor-default"
            aria-label="Close navigation menu"
            data-menu-backdrop
          ></button>
          <div
            class="relative z-10 w-full max-w-sm overflow-hidden rounded-3xl border border-zinc-800 bg-zinc-900/98 shadow-2xl opacity-0 translate-y-6 scale-[0.98] transition duration-200 ease-out motion-reduce:transform-none motion-reduce:transition-none"
            data-menu-panel
          >
            <div class="flex items-center justify-between border-b border-zinc-800 px-5 py-4">
              <div>
                <p class="text-xs font-medium uppercase tracking-[0.24em] text-zinc-500">Navigation</p>
                <h2 id="mobile-menu-title" class="mt-1 text-base font-semibold text-zinc-50">Browse CommerceForge</h2>
              </div>
              <button
                type="button"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-zinc-800 bg-zinc-950 text-zinc-300 transition hover:border-zinc-700 hover:text-zinc-50"
                aria-label="Close navigation menu"
                data-menu-close
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                  <path d="M6 6l12 12" />
                  <path d="M18 6L6 18" />
                </svg>
              </button>
            </div>
            <div class="grid gap-1 p-3 text-sm">
              <a href="https://demo.commerceforge.dev" target="_blank" class="rounded-2xl px-4 py-3 text-zinc-300 transition hover:bg-zinc-800 hover:text-zinc-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400" data-menu-link>Demo</a>
              <a href="#features" class="rounded-2xl px-4 py-3 text-zinc-300 transition hover:bg-zinc-800 hover:text-zinc-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400" data-menu-link>Features</a>
              <a href="#pricing" class="rounded-2xl px-4 py-3 text-zinc-300 transition hover:bg-zinc-800 hover:text-zinc-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400" data-menu-link>Pricing</a>
              <a href="#faq" class="rounded-2xl px-4 py-3 text-zinc-300 transition hover:bg-zinc-800 hover:text-zinc-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400" data-menu-link>FAQ</a>
              <a
                href="#pricing"
                class="mt-3 rounded-2xl bg-indigo-600 px-4 py-3 text-center font-medium text-white transition hover:bg-indigo-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-300"
                data-menu-link
              >
                Get started
              </a>
            </div>
          </div>
        </div>
      </dialog>
    </nav>
  </header>

  <script is:inline>
    const toggle = document.querySelector('[data-menu-toggle]');
    const menu = document.querySelector('[data-mobile-menu]');

    if (toggle instanceof HTMLButtonElement && menu instanceof HTMLDialogElement) {
      const panel = menu.querySelector('[data-menu-panel]');
      const closeButton = menu.querySelector('[data-menu-close]');
      const backdrop = menu.querySelector('[data-menu-backdrop]');
      const links = menu.querySelectorAll('[data-menu-link]');
      const desktopMedia = window.matchMedia('(min-width: 768px)');
      let isClosing = false;

      const syncTriggerState = (isOpen) => {
        toggle.setAttribute('aria-expanded', String(isOpen));
        toggle.setAttribute(
          'aria-label',
          isOpen ? 'Close navigation menu' : 'Open navigation menu',
        );
      };

      const setPanelState = (isOpen) => {
        if (!(panel instanceof HTMLElement)) return;
        panel.classList.toggle('opacity-0', !isOpen);
        panel.classList.toggle('translate-y-6', !isOpen);
        panel.classList.toggle('scale-[0.98]', !isOpen);
        panel.classList.toggle('opacity-100', isOpen);
        panel.classList.toggle('translate-y-0', isOpen);
        panel.classList.toggle('scale-100', isOpen);
      };

      const openMenu = () => {
        if (menu.open || desktopMedia.matches) return;
        menu.showModal();
        document.body.classList.add('overflow-hidden');
        syncTriggerState(true);
        setPanelState(false);
        requestAnimationFrame(() => {
          setPanelState(true);
        });
        if (closeButton instanceof HTMLButtonElement) {
          closeButton.focus();
        }
      };

      const finishClose = () => {
        menu.close();
      };

      const closeMenu = () => {
        if (!menu.open || isClosing) return;
        isClosing = true;
        setPanelState(false);
        window.setTimeout(finishClose, 200);
      };

      toggle.addEventListener('click', () => {
        if (menu.open) {
          closeMenu();
          return;
        }
        openMenu();
      });

      if (closeButton instanceof HTMLButtonElement) {
        closeButton.addEventListener('click', closeMenu);
      }

      if (backdrop instanceof HTMLButtonElement) {
        backdrop.addEventListener('click', closeMenu);
      }

      menu.addEventListener('cancel', (event) => {
        event.preventDefault();
        closeMenu();
      });

      menu.addEventListener('close', () => {
        isClosing = false;
        document.body.classList.remove('overflow-hidden');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open navigation menu');
        setPanelState(false);
        toggle.focus();
      });

      links.forEach((link) => {
        link.addEventListener('click', closeMenu);
      });

      desktopMedia.addEventListener('change', (event) => {
        if (event.matches && menu.open) {
          closeMenu();
        }
      });
    }
  </script>

  <main>
    <!-- ─── HERO ──────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden px-6 pb-24 pt-24 text-center">
      <!-- background grid -->
      <div
        class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,#27272a_1px,transparent_1px),linear-gradient(to_bottom,#27272a_1px,transparent_1px)] bg-[size:48px_48px] opacity-30"
      ></div>
      <!-- radial fade -->
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(99,102,241,0.15),transparent)]"
      ></div>

      <div class="relative mx-auto max-w-4xl">
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-zinc-700 bg-zinc-900 px-4 py-1.5 text-sm text-zinc-400"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-indigo-400"></span>
          Shopify Hydrogen 2026.1 · React Router v7
        </div>

        <h1 class="mb-6 text-5xl font-bold leading-tight tracking-tight text-zinc-50 md:text-6xl">
          The Hydrogen starter<br />
          <span class="text-indigo-400">agencies actually ship with.</span>
        </h1>

        <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-zinc-400">
          B2C + B2B · customer account · predictive search · bundles + subscriptions · 27 locales + RTL.
          One production-ready Hydrogen codebase, packaged for agencies that need to ship v1 fast.
        </p>

        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="#pricing"
            class="whitespace-nowrap rounded-md bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow-lg transition hover:bg-indigo-500"
          >
            Get CommerceForge — from 199 €
          </a>
          <a
            href="https://demo.commerceforge.dev"
            target="_blank"
            class="rounded-md border border-zinc-700 px-8 py-3 text-base font-medium text-zinc-300 transition hover:border-zinc-500 hover:text-zinc-50"
          >
            View demo →
          </a>
        </div>

        <!-- file tree preview -->
        <div
          class="mx-auto mt-16 max-w-lg overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900 text-left shadow-2xl"
        >
          <div class="flex items-center gap-2 border-b border-zinc-800 px-4 py-3">
            <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
            <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
            <span class="ml-2 font-mono text-xs text-zinc-500">commerceforge/</span>
          </div>
          <pre class="px-6 py-5 font-mono text-sm leading-7 text-zinc-400"><code><span class="text-zinc-500">├──</span> app/
<span class="text-zinc-500">│   ├──</span> <span class="text-indigo-400">components/</span>
<span class="text-zinc-500">│   │   ├──</span> <span class="text-zinc-300">ui/</span>                    <span class="text-zinc-600"># 57 shadcn/ui components</span>
<span class="text-zinc-500">│   │   ├──</span> ProductMain.tsx
<span class="text-zinc-500">│   │   ├──</span> CartMain.tsx
<span class="text-zinc-500">│   │   ├──</span> SearchFormPredictive.tsx
<span class="text-zinc-500">│   │   ├──</span> RecentlyViewedProducts.tsx
<span class="text-zinc-500">│   │   └──</span> sections/
<span class="text-zinc-500">│   ├──</span> <span class="text-indigo-400">graphql/customer-account/</span>
<span class="text-zinc-500">│   ├──</span> <span class="text-indigo-400">lib/</span>                   <span class="text-zinc-600"># search, seo, i18n, variants</span>
<span class="text-zinc-500">│   ├──</span> <span class="text-indigo-400">locales/</span>               <span class="text-zinc-600"># 27 languages + RTL</span>
<span class="text-zinc-500">│   ├──</span> <span class="text-indigo-400">routes/</span>                <span class="text-zinc-600"># account, catalog, search, api</span>
<span class="text-zinc-500">│   └──</span> root.tsx
<span class="text-zinc-500">├──</span> <span class="text-indigo-400">guides/</span>                    <span class="text-zinc-600"># install, deploy, env, b2b, i18n</span>
<span class="text-zinc-500">├──</span> public/</code></pre>
        </div>
      </div>
    </section>

    <!-- ─── FEATURES ─────────────────────────────────────────────── -->
    <section id="features" class="px-6 py-24">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
