                )}

                <div class="mb-6">
                  <h3 class="mb-1 text-lg font-semibold text-zinc-50">{tier.name}</h3>
                  <p class="text-sm text-zinc-400">{tier.description}</p>
                </div>

                <div class="mb-6">
                  <span class="text-4xl font-bold text-zinc-50">{tier.price} €</span>
                  <span class="ml-2 text-sm text-zinc-500">one-time</span>
                </div>

                <ul class="mb-8 flex-1 space-y-3">
                  {tier.features.map((f) => (
                    <li class="flex items-center gap-3 text-sm text-zinc-300">
                      <span class="text-indigo-400">✓</span>
                      {f}
                    </li>
                  ))}
                </ul>

                <a
                  href={tier.url}
                  class={`block rounded-md py-3 text-center text-sm font-semibold transition ${
                    tier.highlight
                      ? 'bg-indigo-600 text-white hover:bg-indigo-500'
                      : 'border border-zinc-700 text-zinc-300 hover:border-zinc-500 hover:text-zinc-50'
                  }`}
                >
                  {tier.cta}
                </a>
              </div>
            ))
          }
        </div>

        <p class="mt-8 text-center text-sm text-zinc-500">
          {pricingTaxCopy}
        </p>
        <p class="mt-3 text-center text-sm text-zinc-500">
          {checkoutDeliveryCopy}
        </p>
      </div>
    </section>

    <!-- ─── FAQ ──────────────────────────────────────────────────── -->
    <section id="faq" class="border-t border-zinc-800 px-6 py-24">
      <div class="mx-auto max-w-3xl">
        <div class="mb-16 text-center">
          <h2 class="mb-4 text-3xl font-bold tracking-tight text-zinc-50 md:text-4xl">
            Frequently asked questions.
          </h2>
        </div>

        <div class="divide-y divide-zinc-800">
          {
            faqs.map((faq) => (
              <div class="py-6">
                <h3 class="mb-3 font-medium text-zinc-50">{faq.q}</h3>
                <p class="text-sm leading-relaxed text-zinc-400">{faq.a}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── CTA BOTTOM ───────────────────────────────────────────── -->
    <section class="border-t border-zinc-800 px-6 py-24 text-center">
      <div class="mx-auto max-w-2xl">
        <h2 class="mb-4 text-3xl font-bold tracking-tight text-zinc-50 md:text-4xl">
          Ready to ship your next Shopify store?
        </h2>
        <p class="mb-10 text-zinc-400">
          Skip weeks of boilerplate. Start with a production-ready codebase.
        </p>
        <a
          href="#pricing"
          class="inline-block whitespace-nowrap rounded-md bg-indigo-600 px-8 py-3 text-base font-semibold text-white shadow-lg transition hover:bg-indigo-500 sm:px-10 sm:py-4"
        >
          Get CommerceForge — from 199 €
        </a>
      </div>
    </section>
  </main>

  <!-- ─── FOOTER ───────────────────────────────────────────────── -->
  <footer class="border-t border-zinc-800 px-6 py-10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 sm:flex-row">
      <div>
        <p class="font-semibold text-zinc-50">CommerceForge</p>
        <p class="mt-1 text-sm text-zinc-500">© 2026 CommerceForge. All rights reserved.</p>
      </div>
      <div class="flex items-center gap-6 text-sm text-zinc-500">
        <a href="/terms" class="transition hover:text-zinc-300">Terms</a>
        <a href="/privacy" class="transition hover:text-zinc-300">Privacy</a>
        <a href="mailto:hello@commerceforge.dev" class="transition hover:text-zinc-300"
          >hello@commerceforge.dev</a
        >
      </div>
    </div>
  </footer>
</Base>
