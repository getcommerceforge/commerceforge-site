const faqs = [
  {
    q: 'What version of Shopify Hydrogen is included?',
    a: 'CommerceForge is built on Hydrogen 2026.1 with React Router v7. It follows the official Shopify Hydrogen architecture and is compatible with Shopify Oxygen deployment.',
  },
  {
    q: 'Do I need Shopify Plus for B2B?',
    a: 'Yes. The B2B features (company locations, buyer pricing, quantity rules, volume tiers) require a Shopify Plus plan. All B2C features work on any Shopify plan.',
  },
  {
    q: 'Can I use it for client stores?',
    a: 'Yes. The Pro license covers up to 5 stores and the Agency license covers unlimited stores, including stores built and managed for clients.',
  },
  {
    q: 'What is included in the 12 months of updates?',
    a: 'All improvements, bug fixes, and new features released within 12 months of your purchase date. Updates are delivered as a new version of the codebase.',
  },
  {
    q: 'What ships in version 1.0?',
    a: 'Version 1.0 includes B2C + B2B storefront flows, customer account pages, predictive and full search, bundles, subscriptions, quick view, recommendations, multilingual support, SEO setup, and a production release packaging flow.',
  },
  {
    q: 'Can I customise the code?',
    a: 'Yes. You receive the full source code and can modify anything. The only restriction is redistribution — you may not resell or publish the starter itself.',
