const metrics = [
  { value: '97', label: 'Cart desktop score', unit: '' },
  { value: '99', label: 'Cart mobile score', unit: '' },
  { value: '91+', label: 'PDP desktop score', unit: '' },
  { value: '92+', label: 'Collection desktop score', unit: '' },
];

const components = [
  'Accordion', 'Alert Dialog', 'Avatar', 'Badge', 'Breadcrumb',
  'Button', 'Button Group', 'Calendar', 'Card', 'Carousel',
  'Chart', 'Checkbox', 'Collapsible', 'Combobox', 'Command',
  'Context Menu', 'Dialog', 'Drawer', 'Dropdown Menu', 'Empty State',
  'Field', 'Form', 'Hover Card', 'Input', 'Input Group',
  'Input OTP', 'Item', 'Kbd', 'Label', 'Lightbox',
  'Menubar', 'Navigation Menu', 'Native Select', 'Pagination', 'Popover',
  'Progress', 'Radio Group', 'Resizable', 'Scroll Area', 'Select',
  'Separator', 'Sheet', 'Skeleton', 'Slider', 'Sonner',
  'Spinner', 'Switch', 'Table', 'Tabs', 'Textarea',
  'Toggle', 'Toggle Group', 'Tooltip',
];

const tiers = [
  {
    name: 'Starter',
    price: '199',
    description: 'For a single Shopify storefront.',
    stores: '1 store',
    highlight: false,
    cta: 'Buy Starter',
    url: getCheckoutUrl('Starter'),
    features: [
      '1 production store',
      'Full source code',
      'All features included',
      '30 days email support',
      '12 months updates',
    ],
  },
  {
    name: 'Pro',
    price: '449',
    description: 'For studios managing multiple clients.',
    stores: 'Up to 5 stores',
    highlight: true,
    cta: 'Buy Pro',
    url: getCheckoutUrl('Pro'),
    features: [
      'Up to 5 production stores',
      'Full source code',
      'All features included',
      '30 days email support',
      '12 months updates',
    ],
  },
  {
    name: 'Agency',
    price: '1,499',
    description: 'Unlimited use across all client projects.',
    stores: 'Unlimited stores',
    highlight: false,
    cta: 'Buy Agency',
    url: getCheckoutUrl('Agency'),
    features: [
      'Unlimited production stores',
      'Full source code',
      'All features included',
      '30 days email support',
      '12 months updates',
