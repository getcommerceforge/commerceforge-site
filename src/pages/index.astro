                  <div class="[&>svg]:block [&>svg]:h-5 [&>svg]:w-5" set:html={iconMarkup[f.icon]} />
                </div>
                <h3 class="mb-2 font-semibold text-zinc-50">{f.title}</h3>
                <p class="text-sm leading-relaxed text-zinc-400">{f.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── PERFORMANCE ──────────────────────────────────────────── -->
    <section class="border-y border-zinc-800 bg-zinc-900 px-6 py-24">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
          <h2 class="mb-4 text-3xl font-bold tracking-tight text-zinc-50 md:text-4xl">
            Strong Lighthouse results where it matters.
          </h2>
          <p class="mx-auto max-w-xl text-zinc-400">
            Core transactional pages already perform well on the public demo. Product, collection,
            and cart pages benchmark strongly before any project-specific optimisation pass.
          </p>
        </div>

        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {
            metrics.map((m) => (
              <div class="text-center">
                <div class="mb-2 font-mono text-5xl font-bold text-indigo-400">
                  {m.value}
